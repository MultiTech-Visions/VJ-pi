__pycache__/
*.py[cod]
venv/
venv_face/
vj_state.json
vj_last_run.log
vj_last_update.log
vj_last_process.log
vj_last_cinematic.log
vj_last_4k_process.log
vj_last_fsrule.log
assets/vj_last_4k_process.log
vj_last_portrait_process.log
vj_last_bench.log
vj_last_upload.log
bench_assets/

# Never let git stash / commit grab user media. The clips and
# overlays folders are operator data — large binaries that have no
# business in version control or in `git stash push -u`. Earlier
# Update.sh runs stashed them under "local changes detected" and
# they disappeared from the working tree. Don't repeat that.
assets/clips/*
!assets/clips/.gitkeep
!assets/clips/README*
assets/overlays/*
!assets/overlays/.gitkeep
!assets/overlays/README*
assets/images/*
!assets/images/.gitkeep
!assets/images/README*
assets/4k/*
!assets/4k/.gitkeep
!assets/4k/processed/
assets/4k/processed/*
!assets/4k/processed/.gitkeep
assets/portrait/*
!assets/portrait/.gitkeep
!assets/portrait/landscape/
assets/portrait/landscape/*
!assets/portrait/landscape/.gitkeep
!assets/portrait/rotate/
assets/portrait/rotate/*
!assets/portrait/rotate/.gitkeep
!assets/portrait/crop/
assets/portrait/crop/*
!assets/portrait/crop/.gitkeep

# PC clip baker — don't commit source/output clips or its log
pc_clip_baker/input/*
!pc_clip_baker/input/.gitkeep
pc_clip_baker/output/*
!pc_clip_baker/output/.gitkeep
pc_clip_baker/bake.log
# HEVC decode spike artifacts (local, on the Pi)
vj_last_hevctest.log
vj_last_hevc_worker.log
# HEVC clip library (baked 2K clips live here, like assets/clips)
assets/clips_hevc/*
!assets/clips_hevc/.gitkeep

# Baked face point clouds — operator media, like assets/clips. The .npz
# files are captured locally via "Capture Face.sh"; keep the folder + docs.
assets/faces/*
!assets/faces/.gitkeep
!assets/faces/README*
vj_last_capture.log

# projectM (MilkDrop) — built library + downloaded preset/texture packs
# (installed by "Setup ProjectM.sh"), plus the operator's local playlist.
vendor/
assets/projectm_presets/
assets/projectm_textures/
projectm_playlist.txt
vj_last_projectm_setup.log

# Catch-all for run logs + local test media so a stray `git add -A` can't
# sweep them in (a 68MB test mp4 + spike logs got committed once).
vj_last_*.log
tests/*.mp4
tests/*.mov
tests/*.mkv
