__pycache__/
*.py[cod]
venv/
vj_state.json
vj_last_run.log
vj_last_update.log
vj_last_process.log
vj_last_cinematic.log
vj_last_4k_process.log
vj_last_fsrule.log
assets/vj_last_4k_process.log
vj_last_portrait_process.log
