__pycache__/
*.py[cod]
venv/
vj_state.json
vj_last_run.log
vj_last_update.log
vj_last_process.log
vj_last_cinematic.log
vj_last_4k_process.log
vj_last_fsrule.log
assets/vj_last_4k_process.log
vj_last_portrait_process.log

# Never let git stash / commit grab user media. The clips and
# overlays folders are operator data — large binaries that have no
# business in version control or in `git stash push -u`. Earlier
# Update.sh runs stashed them under "local changes detected" and
# they disappeared from the working tree. Don't repeat that.
assets/clips/*
!assets/clips/.gitkeep
!assets/clips/README*
assets/overlays/*
!assets/overlays/.gitkeep
!assets/overlays/README*
assets/images/*
!assets/images/.gitkeep
!assets/images/README*
assets/4k/*
!assets/4k/.gitkeep
!assets/4k/processed/
assets/4k/processed/*
!assets/4k/processed/.gitkeep
assets/portrait/*
!assets/portrait/.gitkeep
!assets/portrait/landscape/
assets/portrait/landscape/*
!assets/portrait/landscape/.gitkeep
